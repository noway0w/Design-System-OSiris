# Copy to .platform-sso.env (gitignored). Readable by php-fpm (nginx).

# Google SSO
# PLATFORM_SSO_GOOGLE_CLIENT_ID=
# PLATFORM_SSO_GOOGLE_CLIENT_SECRET=
# PLATFORM_SSO_STATE_SECRET=
# PLATFORM_PUBLIC_BASE_URL=https://app.guillaumelassiat.com

# Outbound mail (required for verification / password reset emails)
# IONOS SMTP (verification emails from noreply@guillaumelassiat.com):
#   scripts/setup-platform-mail.sh ionos --file /path/to/mailbox-password.txt
PLATFORM_MAIL_FROM="OSiris <noreply@guillaumelassiat.com>"
PLATFORM_MAIL_PROVIDER=smtp
PLATFORM_MAIL_DEV_EXPOSE_LINK=0
PLATFORM_SMTP_HOST=smtp.ionos.fr
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USER=noreply@guillaumelassiat.com
PLATFORM_SMTP_TLS=starttls
# Password in .platform-mail.secret (not this file):
# PLATFORM_SMTP_PASS=...
